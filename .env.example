# Valor AI Environment Configuration

# === LOCAL vLLM ENDPOINTS (Docker via WSL2) ===

# Manager -- GPU 0: DeepSeek-R1-Distill-Qwen-32B-abliterated-AWQ
VLLM_MANAGER_URL=http://localhost:8000/v1
MANAGER_MODEL=huihui-ai/DeepSeek-R1-Distill-Qwen-32B-abliterated-AWQ

# Workers -- GPU 1: Qwen3-8B-AWQ (continuous batching, 16 concurrent)
VLLM_WORKER_URL=http://localhost:8001/v1
WORKER_MODEL=Qwen/Qwen3-8B-AWQ

# Deep Dive -- Both GPUs, TP=2: Llama-3.3-70B-AWQ (only when Lanes 1+2 are down)
VLLM_DEEPDIVE_URL=http://localhost:8000/v1
DEEPDIVE_MODEL=ibnzterrell/Meta-Llama-3.3-70B-Instruct-AWQ-INT4

# HuggingFace token (for gated model downloads)
HF_TOKEN=your_hf_token_here

# === CLOUD FALLBACKS ===
XAI_API_KEY=your_xai_key_here
XAI_MODEL=grok-4-1-fast-reasoning
ANTHROPIC_API_KEY=your_anthropic_key_here

# === TOOLS ===
APIFY_TOKEN=your_apify_token_here
FIRECRAWL_API_KEY=your_firecrawl_key_here
BRAVE_SEARCH_API_KEY=your_brave_key_here

# === INFRASTRUCTURE ===

# Redis (for BullMQ job queue)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Workers
WORKER_COUNT=3
WORKER_HEARTBEAT_INTERVAL_MS=5000

# Rate Limiting
APIFY_MIN_TIME_MS=3000
FIRECRAWL_MIN_TIME_MS=1000
BRAVE_MIN_TIME_MS=200

# BigQuery
GOOGLE_APPLICATION_CREDENTIALS=C:\Users\Big Levi Local\.claude\keys\valorinvestigates-bigquery.json
BIGQUERY_PROJECT=valorinvestigates
BIGQUERY_DATASET=valor_investigations

# Server
API_PORT=3000
DASHBOARD_PORT=5173

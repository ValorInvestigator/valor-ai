# Valor AI Environment Configuration

# LLM Providers
VLLM_BASE_URL=http://localhost:8000/v1
XAI_API_KEY=your_xai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here

# Default LLM (local | xai | claude)
DEFAULT_LLM=local
LOCAL_MODEL=Qwen/Qwen3-32B-AWQ
XAI_MODEL=grok-4-1-fast-reasoning

# Tools
APIFY_TOKEN=your_apify_token_here
FIRECRAWL_API_KEY=your_firecrawl_key_here
BRAVE_SEARCH_API_KEY=your_brave_key_here

# Redis (for BullMQ job queue)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Workers
WORKER_COUNT=3
WORKER_HEARTBEAT_INTERVAL_MS=5000

# Rate Limiting
APIFY_MIN_TIME_MS=3000
FIRECRAWL_MIN_TIME_MS=1000
BRAVE_MIN_TIME_MS=200

# BigQuery
GOOGLE_APPLICATION_CREDENTIALS=C:\Users\Big Levi Local\.claude\keys\valorinvestigates-bigquery.json
BIGQUERY_PROJECT=valorinvestigates
BIGQUERY_DATASET=valor_investigations

# Server
API_PORT=3000
DASHBOARD_PORT=5173
